{
  "name": "instagram-comment-dm",
  "version": "1.0.0",
  "description": "Automated Instagram Comment-to-DM replies via Meta Graph API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=src/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=src/prisma/schema.prisma",
    "postinstall": "npx prisma generate --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "dotenv": "^16.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
