# ─────────────────────────────────────────────
# Instagram Comment-to-DM — Environment Config
# ─────────────────────────────────────────────

# Meta / Facebook App credentials
PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
APP_SECRET=your_facebook_app_secret_here
VERIFY_TOKEN=your_custom_webhook_verify_token_here

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/instagram_comment_dm

# Redis connection string (for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Trigger settings
TRIGGER_KEYWORD=ORDER
DM_MESSAGE_TEXT=Hey! Click the button below to get your link:

# Optional button (remove or leave empty to send plain text only)
# When both are set, the DM includes a clickable "Get Link" button
DM_BUTTON_TITLE=Get Link
DM_BUTTON_URL=https://your-website.com/link

# Server
PORT=3000
